# --- BoxdRank environment ---
FLASK_DEBUG=false
PORT=5000

# REQUIRED in production: a long random string.
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Your domain (shown on the share card + links). Host only, no https://
BOXDRANK_DOMAIN=boxdrank.app

# Actor/director headshots come from Wikipedia/Wikimedia — free, no API key.
# (Images are cached in the DB; most are CC-BY-SA, so a small "photos via
# Wikimedia" credit is the clean thing to add on a commercial site.)

# Persist the SQLite DB on a durable disk so the leaderboard survives deploys.
# On a DigitalOcean Droplet, point this at an attached volume:
# BOXDRANK_DB_PATH=/data/boxdrank.db

# Minutes before a rank is re-scraped on lookup (lower = fresher, more scraping)
BOXDRANK_REFRESH_MIN=10

# Background auto-refresher. 0 = OFF (this build uses the "connect again" nudge).
# If you set it to 1, run gunicorn with a SINGLE worker so it doesn't run twice.
BOXDRANK_BG_REFRESH=0
