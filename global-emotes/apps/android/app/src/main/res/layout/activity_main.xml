<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="28dp"
        android:paddingBottom="28dp">

        <!-- ===== HERO ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/hero_gradient"
            android:padding="24dp"
            android:elevation="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_frost"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:text="@string/hero_badge"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="🌐"
                android:textSize="44sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/hero_title"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/hero_tagline"
                android:textColor="#F2EAFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- ===== SETUP CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Text.Kicker"
                    android:text="@string/setup_kicker" />

                <TextView
                    style="@style/Text.CardTitle"
                    android:text="@string/setup_title" />

                <!-- step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Text.StepDot"
                        android:text="1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView style="@style/Text.StepTitle" android:text="@string/step1_title" />
                        <TextView style="@style/Text.StepBody" android:text="@string/step1_body" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/enable_keyboard"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:minHeight="54dp"
                    android:text="@string/enable_keyboard"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <!-- step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Text.StepDot"
                        android:text="2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView style="@style/Text.StepTitle" android:text="@string/step2_title" />
                        <TextView style="@style/Text.StepBody" android:text="@string/step2_body" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/switch_keyboard"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:minHeight="54dp"
                    android:text="@string/switch_keyboard"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== PACK CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Text.Kicker"
                    android:text="@string/pack_kicker" />

                <TextView
                    style="@style/Text.CardTitle"
                    android:text="@string/pack_title" />

                <TextView
                    android:id="@+id/pack_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/badge_soft"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/Text.StepBody"
                    android:layout_marginTop="12dp"
                    android:text="@string/pack_body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/add_emote"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:minHeight="54dp"
                    android:text="@string/add_emote"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/brand_pink"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== PRIVACY CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/primary_container"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_kicker"
                    android:textColor="@color/on_primary_container"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/privacy_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/keyboard_privacy_explainer"
                    android:textColor="@color/on_primary_container"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/footer_sig"
            android:textColor="@color/on_surface_muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
