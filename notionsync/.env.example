# Copy to .env for local development. `shopify app dev` fills in the Shopify
# values automatically in dev — you mainly need this file for production.
# Every variable is documented in README.md.

# --- Shopify app credentials (Partner Dashboard → your app → Overview) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# The public URL of the app. In dev the CLI tunnels for you; in production
# this is your Railway domain, e.g. https://airsync-production.up.railway.app
SHOPIFY_APP_URL=

# Must match the scopes in shopify.app.toml
SCOPES=read_orders,read_all_orders,read_products

# --- Database ---
# Production only (PostgreSQL). Dev uses SQLite automatically (prisma/dev.sqlite).
DATABASE_URL=

# --- NotionSync secrets ---
# 32+ random characters. Encrypts merchants' Notion tokens at rest.
# Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=

# Billing: "true" creates Shopify TEST charges (never real money).
# Set to "false" in production so merchants are actually billed.
BILLING_TEST=true
